# Copy to .env and adjust for your machine. Never commit real secrets.
KNOWLEDGE_COLLECTOR_PORT=8080
KNOWLEDGE_COLLECTOR_DATA_DIR=./data
KNOWLEDGE_COLLECTOR_SERVER_ADDRESS=127.0.0.1
KNOWLEDGE_COLLECTOR_SERVER_PORT=8080
KNOWLEDGE_COLLECTOR_TASK_STALE_TIMEOUT=PT10M
KNOWLEDGE_COLLECTOR_SECURITY_ENABLED=true
KNOWLEDGE_COLLECTOR_INITIAL_ADMIN_USERNAME=admin
KNOWLEDGE_COLLECTOR_INITIAL_ADMIN_PASSWORD=replace-with-strong-initial-password
KNOWLEDGE_COLLECTOR_SESSION_TIMEOUT=8h
KNOWLEDGE_COLLECTOR_TRUST_SYSTEM_STORE=true
KNOWLEDGE_COLLECTOR_ADDITIONAL_CA_FILE=
KNOWLEDGE_COLLECTOR_AI_PROVIDER=ollama
KNOWLEDGE_COLLECTOR_AI_MAX_CONTENT_CHARS=24000
KNOWLEDGE_COLLECTOR_AI_CHAT_MAX_HISTORY=20
KNOWLEDGE_COLLECTOR_OLLAMA_ENABLED=true
KNOWLEDGE_COLLECTOR_OLLAMA_BASE_URL=http://127.0.0.1:11434
KNOWLEDGE_COLLECTOR_OLLAMA_MODEL=deepseek-r1:14b
KNOWLEDGE_COLLECTOR_OLLAMA_TIMEOUT=PT2M
KNOWLEDGE_COLLECTOR_FIRECRAWL_ENABLED=false
KNOWLEDGE_COLLECTOR_FIRECRAWL_BASE_URL=http://127.0.0.1:3002
KNOWLEDGE_COLLECTOR_FIRECRAWL_API_KEY=
KNOWLEDGE_COLLECTOR_PLAYWRIGHT_ENABLED=false
KNOWLEDGE_COLLECTOR_PLAYWRIGHT_BASE_URL=http://127.0.0.1:3003
KNOWLEDGE_COLLECTOR_MINIO_ENABLED=false
KNOWLEDGE_COLLECTOR_MINIO_ENDPOINT=http://127.0.0.1:9000
KNOWLEDGE_COLLECTOR_MINIO_BUCKET=knowledge-collector
KNOWLEDGE_COLLECTOR_MINIO_ACCESS_KEY=knowledge
KNOWLEDGE_COLLECTOR_MINIO_SECRET_KEY=change-this-password
MINIO_ROOT_USER=knowledge
MINIO_ROOT_PASSWORD=change-this-password
TIKA_PORT=127.0.0.1:9998
QDRANT_PORT=127.0.0.1:6333
NTFY_PORT=127.0.0.1:8085
PROMETHEUS_PORT=127.0.0.1:9090
GRAFANA_PORT=127.0.0.1:3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-this-grafana-password
N8N_PORT=127.0.0.1:5678
N8N_ENCRYPTION_KEY=replace-with-at-least-32-random-characters
# n8n 2.x has no default account. Create the Owner account on first visit to http://127.0.0.1:5678.
# Optional external/cloud integrations; leave blank to keep them disabled.
KNOWLEDGE_COLLECTOR_CLOUD_LLM_ENDPOINT=
KNOWLEDGE_COLLECTOR_CLOUD_LLM_API_KEY=
KNOWLEDGE_COLLECTOR_LANGFUSE_URL=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# Docker Desktop proxy is configured in Settings > Resources > Proxies, not passed to app containers.
# Verified Windows example: HTTP proxy and HTTPS proxy both use http://127.0.0.1:7890
